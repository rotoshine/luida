{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luida",
  "version": "0.0.0",
  "identifier": "com.daangn.luida",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:4322",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "🍺 루이다의 주점",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' data: https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:4321 ws://127.0.0.1:4321"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [],
    "category": "DeveloperTool",
    "copyright": "© 2026 roto"
  }
}
